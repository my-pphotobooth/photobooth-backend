PORT=3000
DATABASE_URL=postgres://photobooth:photobooth@localhost:5433/photobooth
PUBLIC_BASE_URL=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_BYTES=5242880
CORS_ORIGIN=http://localhost:5173

# Storage driver: local | s3
STORAGE_DRIVER=local

# Required when STORAGE_DRIVER=s3
# AWS_REGION=ap-northeast-2
# S3_BUCKET=my-photobooth-uploads
# S3_PUBLIC_BASE_URL=  # optional CloudFront URL, defaults to bucket URL

# Credentials (when STORAGE_DRIVER=s3):
# - Local dev: `aws configure` 또는 AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY env
# - EC2 production: IAM Instance Profile (코드/env 불필요)
