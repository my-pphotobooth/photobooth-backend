{
  "name": "my-photobooth-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "migrate": "node-pg-migrate -j sql --envPath .env -m src/db/migrations up",
    "migrate:down": "node-pg-migrate -j sql --envPath .env -m src/db/migrations down",
    "migrate:create": "node-pg-migrate -j sql --envPath .env -m src/db/migrations create"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "express-rate-limit": "^7.4.1",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "node-pg-migrate": "^7.6.1"
  }
}
